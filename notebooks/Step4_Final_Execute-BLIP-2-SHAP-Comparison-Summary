RA adapters from saved model...\n","✅ LoRA adapters loaded successfully!\n","\n","✅ BLIP-2 model loaded successfully!\n","   Model type: PeftModelForCausalLM\n"]}]},{"cell_type":"code","source":["#============================================================================\n","# CELL 6: CREATE TEST DATASET\n","#============================================================================\n","print(\"=\" * 80)\n","print(\"📊 CREATING TEST DATASET\")\n","print(\"=\" * 80)\n","\n","test_dataset = RAFCEDataset(\n","    Config.DATA_DIR,\n","    Config.LABEL_FILE,\n","    Config.PARTITION_FILE,\n","    processor,\n","    au_file=Config.AU_FILE,\n","    split='test',\n","    use_explain=True\n",")\n","\n","print(f\"✅ Test dataset: {len(test_dataset)} samples\")"],"metadata":{"id":"MZrR38tYcnA_","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1768914494628,"user_tz":-60,"elapsed":3287,"user":{"displayName":"Rana Romdhane","userId":"04431319335866376684"}},"outputId":"d2d6fb64-3118-4ee8-fe51-77e21bbd48aa"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["================================================================================\n","📊 CREATING TEST DATASET\n","================================================================================\n","\n","TEST Dataset: 909 samples\n","✅ Test dataset: 909 samples\n"]}]},{"cell_type":"code","source":["#============================================================================\n","# CELL 7: SHAP EXPLAINER - GRID MODE\n","#============================================================================\n","print(\"=\" * 80)\n","print(\"🔍 SHAP ANALYSIS\")\n","print(\"=\" * 80)\n","\n","import shap\n","\n","# Prepare sample\n","sample_shap = test_dataset[0]\n","img_small = np.array(sample_shap['image'].resize((128, 128)))\n","\n","# Create grid segments manually (8x8 = 64 zones)\n","GRID_SIZE = 8\n","H, W = 128, 128\n","h_step, w_step = H // GRID_SIZE, W // GRID_SIZE\n","\n","segments_grid = np.zeros((H, W), dtype=int)\n","counter = 0\n","for i in range(GRID_SIZE):\n","    for j in range(GRID_SIZE):\n","        segments_grid[i*h_step:(i+1)*h_step, j*w_step:(j+1)*w_step] = counter\n","        counter += 1\n","\n","# Masking function\n","def mask_grid_segments(mask, image):\n","    out = np.zeros_like(image)\n","    for i, m in enumerate(mask):\n","        if m:\n","            out[segments_grid == i] = image[segments_grid == i]\n","    return out\n","\n","# Wrapped model for SHAP\n","class Blip2Wrapper(torch.nn.Module):\n","    def __init__(self, model):\n","        super().__init__()\n","        self.model = model\n","\n","    def forward(self, x):\n","        outputs = self.model.vision_model(pixel_values=x)\n","        return outputs.last_hidden_state.mean(dim=1)\n","\n","wrapped_model = Blip2Wrapper(model)\n","\n","# Prediction function for SHAP\n","def grid_predict_fn(masks):\n","    images_to_predict = np.array([mask_grid_segments(m, img_small) for m in masks])\n","    imgs_pil = [Image.fromarray(img.astype('uint8')) for img in images_to_predict]\n","    inputs = processor(images=imgs_pil, return_tensors=\"pt\").to(Config.DEVICE)\n","    with torch.no_grad():\n","        outputs = wrapped_model(inputs.pixel_values)\n","    return F.softmax(outputs, dim=-1).cpu().numpy()\n","\n","# Compute SHAP values\n","print(\"Computing SHAP values (this may take a few minutes)...\")\n","explainer = shap.KernelExplainer(grid_predict_fn, np.zeros((1, GRID_SIZE**2)))\n","shap_values = explainer.shap_values(np.ones((1, GRID_SIZE**2)), nsamples=100)\n","\n","# Get prediction\n","probs = grid_predict_fn(np.ones((1, GRID_SIZE**2)))\n","pred_idx = probs.argmax()\n","pred_label = Config.CLASSES.get(pred_idx, f\"Class {pred_idx}\")\n","\n","# Reconstruct heatmap\n","def fill_grid(values):\n","    out = np.zeros((H, W))\n","    for i in range(len(values)):\n","        out[segments_grid == i] = values[i]\n","    return out\n","\n","# Visualization\n","plt.figure(figsize=(12, 5))\n","\n","plt.subplot(1, 2, 1)\n","plt.imshow(img_small)\n","plt.title(f\"Original Image\\nTrue: {sample_shap['label_text']}\", fontweight='bold')\n","plt.axis('off')\n","\n","plt.subplot(1, 2, 2)\n","if isinstance(shap_values, list):\n","    m = fill_grid(shap_values[pred_idx][0])\n","else:\n","    m = fill_grid(shap_values[0, :, pred_idx])\n","plt.imshow(img_small, alpha=0.4)\n","plt.imshow(m, cmap='RdBu_r', vmin=-np.max(np.abs(m)), vmax=np.max(np.abs(m)), alpha=0.7)\n","plt.colorbar(label='SHAP Value')\n","plt.title(f\"SHAP Importance\\nPredicted: {pred_label}\", fontweight='bold')\n","plt.axis('off')\n","\n","plt.tight_layout()\n","plt.savefig(Config.RESULTS_DIR / 'shap_analysis.png', dpi=300, bbox_inches='tight')\n","plt.show()\n","\n","print(f\"✅ SHAP analysis saved to: {Config.RESULTS_DIR / 'shap_analysis.png'}\")\n","clear_gpu_memory()"],"metadata":{"id":"Swp9fDvNcppg","colab":{"base_uri":"https://localhost:8080/","height":450,"referenced_widgets":["655fea05ae73497c932dfc9095f15b5b","204df61b8e51475385fa0a752dc15b82","c67b508bf9bb440ab6fe88ee50ae74a4","fd5c744b1f7a4e62a1eda1f07b93a349","89a992a4ab9944249fcf1cf77d1e03c0","d9c9a30dd08c4e5db02e2eebe7f6da5c","b911f4a6bb454e7389cfacacd019d8d2","e4e24239446843079492003532843393","cef6aad31f5944fb909bace07ed43307","992a5de56f4b4feb93334f01e014da3c","5ca7aa0dd82848dead9b4d97e62c31cb"]},"executionInfo":{"status":"ok","timestamp":1768914539406,"user_tz":-60,"elapsed":36482,"user":{"displayName":"Rana Romdhane","userId":"04431319335866376684"}},"outputId":"6337b49e-f9da-4be1-850a-4b29433ded9a"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["================================================================================\n","🔍 SHAP ANALYSIS\n","================================================================================\n","Computing SHAP values (this may take a few minutes)...\n"]},{"output_type":"display_data","data":{"text/plain":["  0%|          |