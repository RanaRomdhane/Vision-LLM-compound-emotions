{BLIP2_MODEL_DIR.exists()}\")\n","print(f\"   Results directory exists: {RESULTS_DIR.exists()}\")\n","\n","# List BLIP-2 model contents if exists\n","if BLIP2_MODEL_DIR.exists():\n","    print(f\"\\n📁 BLIP-2 Model Contents:\")\n","    for f in list(BLIP2_MODEL_DIR.iterdir())[:10]:\n","        print(f\"      - {f.name}\")\n","else:\n","    print(f\"   ❌ BLIP-2 model NOT found at {BLIP2_MODEL_DIR}\")\n","    print(f\"   Please check if the path is correct!\")"],"metadata":{"id":"a8PYtnXNcZom","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1768914047653,"user_tz":-60,"elapsed":22616,"user":{"displayName":"Rana Romdhane","userId":"04431319335866376684"}},"outputId":"48a93ca1-f6a5-43fd-f3ac-6d15d7fab84b"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","✅ Paths configured:\n","   Data: /content/drive/Shareddrives/Vision-LLM-Project-Team/dataset/raw/aligned\n","   BLIP-2 Model: /content/drive/Shareddrives/Vision-LLM-Project-Team/models/blip2-model/best_model\n","   BLIP-2 Results: /content/drive/Shareddrives/Vision-LLM-Project-Team/results/results_blip2\n","   General Results: /content/drive/Shareddrives/Vision-LLM-Project-Team/results\n","\n","🔍 Path Verification:\n","   Data directory exists: True\n","   BLIP-2 model exists: True\n","   Results directory exists: True\n","\n","📁 BLIP-2 Model Contents:\n","      - README.md\n","      - added_tokens.json\n","      - merges.txt\n","      - adapter_model.safetensors\n","      - special_tokens_map.json\n","      - tokenizer.json\n","      - adapter_config.json\n","      - tokenizer_config.json\n","      - preprocessor_config.json\n","      - vocab.json\n"]}]},{"cell_type":"code","source":["#============================================================================\n","# CELL 3: CONFIGURATION\n","#============================================================================\n","class Config:\n","    # Paths\n","    DATA_DIR = DATA_DIR\n","    LABEL_FILE = LABEL_FILE\n","    PARTITION_FILE = PARTITION_FILE\n","    AU_FILE = AU_FILE\n","    MODELS_DIR = MODELS_DIR\n","    RESULTS_DIR = BLIP2_RESULTS_DIR\n","\n","    # Model\n","    MODEL_NAME = \"Salesforce/blip2-opt-2.7b\"\n","    BATCH_SIZE = 1\n","    MAX_NEW_TOKENS = 64\n","\n","    # Classes\n","    CLASSES = {\n","        0: \"happily surprised\", 1: \"happily disgusted\", 2: \"sadly fearful\",\n","        3: \"sadly angry\", 4: \"sadly surprised\", 5: \"sadly disgusted\",\n","        6: \"fearfully angry\", 7: \"fearfully surprised\", 8: \"fearfully disgusted\",\n","        9: \"angrily surprised\", 10: \"angrily disgusted\", 11: \"disgustedly surprised\",\n","        12: \"happily fearful\", 13: \"happily sad\"\n","    }\n","    NUM_CLASSES = 14\n","\n","    # Device\n","    DEVICE = device\n","    SEED = 42\n","\n","torch.manual_seed(Config.SEED)\n","np.random.seed(Config.SEED)\n","\n","print(\"⚙️ Configuration loaded:\")\n","print(f\"   Device: {Config.DEVICE}\")\n","print(f\"   Model: {Config.MODEL_NAME}\")\n","print(f\"   Classes: {Config.NUM_CLASSES}\")"],"metadata":{"id":"SkdKesabccpG","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1768914068626,"user_tz":-60,"elapsed":230,"user":{"displayName":"Rana Romdhane","userId":"04431319335866376684"}},"outputId":"90d8720a-0638-4e23-eb46-e9362a5af230"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["⚙️ Configuration loaded:\n","   Device: cuda\n","   Model: Salesforce/blip2-opt-2.7b\n","   Classes: 14\n"]}]},{"cell_type":"code","source":["#============================================================================\n","# CELL 4: DATASET CLASS\n","#============================================================================\n","class RAFCEDataset(Dataset):\n","    \"\"\"RAF-CE Dataset for BLIP-2\"\"\"\n","\n","    def __init__(self, img_dir, label_file, partition_file, processor,\n","                 au_file=None, split='train', use_explain=True):\n","        self.img_dir = Path(img_dir)\n","        self.processor = processor\n","        self.split = split\n","        self.use_explain = use_explain\n","\n","        # Load labels\n","        df_labels = pd.read_csv(label_file, sep=' ', header=None, names=['image', 'label'])\n","        df_part = pd.read_csv(partition_file, sep=' ', header=None, names=['image', 'partition'])\n","        df = pd.merge(df_labels, df_part, on='image')\n","\n","        # Load AU annotations if available\n","        self.au_data = None\n","        if au_file and Path(au_file).exists():\n","            try:\n","                au_df = pd.read_csv(au_file, sep=' ', header=None)\n","                au_df.columns = ['image'] + [f'AU{i}' for i in range(1, len(au_df.columns))]\n","                self.au_data = au_df\n","                df = pd.merge(df, au_df, on='image', how='left')\n","                print(f\"  ✅ Action Units loaded\")\n","            except Exception as e:\n","                print(f\"  ⚠️ Could not load AU data: {e}\")\n","\n","        # Filter by split\n","        split_map = {'train': 0, 'val': 2, 'test': 1}\n","        self.data = df[df['partition'] == split_map[split]].reset_index(drop=True)\n","\n","        # Verify images exist\n","        valid_idx = [i for i, r in self.data.iterrows() if self._find_image(r['image'])]\n","        self.data = self.data.loc[valid_idx].reset_index(drop=True)\n","\n","        print(f\"\\n{split.upper()} Dataset: {len(self)} samples\")\n","\n","    def _find_image(self, img_name):\n","        for name in [img_name, img_name + '.jpg', img_name.replace('.jpg', '') + '_aligned.jpg']:\n","            path = self.img_dir / name\n","            if path.exists():\n","                return path\n","        return None\n","\n","    def _create_prompt(self, row):\n","        emotion = Config.CLASSES.get(row['label'], 'this emotion')\n","        return f\"Question: Describe the facial expression and why it shows {emotion}. Answer:\"\n","\n","    def __len__(self):\n","        return len(self.data)\n","\n","    def __getitem__(self, idx):\n","        if torch.is_tensor(idx):\n","            idx = idx.tolist()\n","        if isinstance(idx, list):\n","            idx = idx[0]\n","        idx = int(idx)\n","\n","        row = self.data.iloc[idx]\n","        img_path = self._find_image(row['image'])\n","        image = Image.open(img_path).convert('RGB')\n","\n","        # AU info\n","        au_info = \"No AU info\"\n","        if self.au_data is not None:\n","            au_columns = [col for col in row.index if col.startswith('AU')]\n","            if au_columns:\n","                au_values = row[au_columns].to_dict()\n","                au_info = \", \".join([f\"{k}:{v}\" for k, v in au_values.items() if v > 0])\n","\n","        label_text = Config.CLASSES[int(row['label'])]\n","\n","        return {\n","            'image': image,\n","            'prompt': self._create_prompt(row),\n","            'target': f\"Emotion: {label_text}\",\n","            'label': int(row['label']),\n","            'au_info': au_info,\n","            'label_text': label_text\n","        }\n","\n","print(\"✅ Dataset class defined\")"],"metadata":{"id":"KA4JT4opcgev","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1768914075440,"user_tz":-60,"elapsed":75,"user":{"displayName":"Rana Romdhane","userId":"04431319335866376684"}},"outputId":"0e042cfe-62e9-42d8-a17a-7272650ed23a"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Dataset class defined\n"]}]},{"cell_type":"code","source":["#============================================================================\n","# CELL 5: LOAD BLIP-2 MODEL FROM DRIVE (FIXED)\n","#============================================================================\n","print(\"=\" * 80)\n","print(\"🤖 LOADING BLIP-2 MODEL FROM DRIVE\")\n","print(\"=\" * 80)\n","\n","clear_gpu_memory()\n","\n","from transformers import Blip2Processor, Blip2ForConditionalGeneration, BitsAndBytesConfig\n","from peft import PeftModel\n","\n","# Verify model path exists\n","if not BLIP2_MODEL_DIR.exists():\n","    raise FileNotFoundError(f\"BLIP-2 model not found at: {BLIP2_MODEL_DIR}\")\n","\n","print(f\"📂 Loading from: {BLIP2_MODEL_DIR}\")\n","\n","# Check if processor files exist in the saved model\n","processor_files = ['preprocessor_config.json', 'tokenizer_config.json']\n","has_processor = any((BLIP2_MODEL_DIR / f).exists() for f in processor_files)\n","\n","if has_processor:\n","    print(\"📥 Loading processor from saved model...\")\n","    processor = Blip2Processor.from_pretrained(BLIP2_MODEL_DIR)\n","else:\n","    print(\"📥 Loading processor from HuggingFace (not in saved model)...\")\n","    processor = Blip2Processor.from_pretrained(Config.MODEL_NAME)\n","\n","# Quantization config\n","quant_config = BitsAndBytesConfig(\n","    load_in_4bit=True,\n","    bnb_4bit_compute_dtype=torch.float16,\n","    bnb_4bit_use_double_quant=True,\n","    bnb_4bit_quant_type=\"nf4\"\n",")\n","\n","# Load base model\n","print(\"📥 Loading base model (this may take 2-3 minutes)...\")\n","base_model = Blip2ForConditionalGeneration.from_pretrained(\n","    Config.MODEL_NAME,\n","    quantization_config=quant_config,\n","    device_map=\"auto\",\n","    torch_dtype=torch.float16\n",")\n","\n","# Load LoRA adapters from your saved model\n","print(\"📥 Loading LoRA adapters from saved model...\")\n","try:\n","    model = PeftModel.from_pretrained(\n","        base_model,\n","        BLIP2_MODEL_DIR,\n","        is_trainable=False\n","    )\n","    print(\"✅ LoRA adapters loaded successfully!\")\n","except Exception as e:\n","    print(f\"⚠️ Could not load LoRA adapters: {e}\")\n","    print(\"   Using base model without LoRA...\")\n","    model = base_model\n","\n","model.eval()\n","\n","print(\"\\n✅ BLIP-2 model loaded successfully!\")\n","print(f\"   Model type: {type(model).__nam