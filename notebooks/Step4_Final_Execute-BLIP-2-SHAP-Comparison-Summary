_values\n","    pixel_values.requires_grad = True\n","\n","    # Get prediction\n","    with torch.no_grad():\n","        features = wrapped_model(pixel_values)\n","        pred_label = features.argmax(dim=1).item()\n","\n","    # Generate Grad-CAM\n","    targets = [ClassifierOutputTarget(label_idx)]\n","    with torch.set_grad_enabled(True):\n","        grayscale_cam = cam(input_tensor=pixel_values, targets=targets)[0, :]\n","\n","    # Prepare display\n","    img_display = np.array(img_pil.resize((224, 224))) / 255.0\n","    cam_image = show_cam_on_image(img_display, grayscale_cam, use_rgb=True)\n","\n","    # Plot original\n","    axes[0, idx].imshow(img_display)\n","    axes[0, idx].set_title(f'True: {label_text[:15]}', fontsize=9)\n","    axes[0, idx].axis('off')\n","\n","    # Plot Grad-CAM\n","    axes[1, idx].imshow(cam_image)\n","    color = 'green' if pred_label == label_idx else 'red'\n","    axes[1, idx].set_title(f'Focus Zones', fontsize=9, color='blue', fontweight='bold')\n","    axes[1, idx].axis('off')\n","\n","model.eval()\n","\n","plt.suptitle('Grad-CAM Visual Interpretability - BLIP-2', fontsize=16, fontweight='bold', y=1.02)\n","plt.tight_layout()\n","plt.savefig(Config.RESULTS_DIR / 'gradcam' / 'gradcam_visualization.png', dpi=300, bbox_inches='tight')\n","plt.show()\n","\n","print(f\"✅ Grad-CAM saved to: {Config.RESULTS_DIR / 'gradcam'}\")\n","clear_gpu_memory()"],"metadata":{"id":"trb9LpwScst0","colab":{"base_uri":"https://localhost:8080/","height":354},"executionInfo":{"status":"ok","timestamp":1768914581175,"user_tz":-60,"elapsed":10405,"user":{"displayName":"Rana Romdhane","userId":"04431319335866376684"}},"outputId":"29bab378-67ec-4e48-8893-c4c9d632f37b"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["================================================================================\n","🔍 GRAD-CAM VISUALIZATION\n","================================================================================\n","Generatin