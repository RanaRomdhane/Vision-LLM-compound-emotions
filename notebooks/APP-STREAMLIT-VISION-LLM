    letter-spacing: 1px;\n","    }\n","\n","    .prediction-box {\n","        background: linear-gradient(145deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.15));\n","        border: 2px solid rgba(139, 92, 246, 0.4);\n","        border-radius: 16px;\n","        padding: 1.25rem;\n","        text-align: center;\n","        margin: 0.5rem 0;\n","    }\n","\n","    .explainability-card {\n","        background: linear-gradient(145deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.1));\n","        border: 1px solid rgba(16, 185, 129, 0.3);\n","        border-radius: 12px;\n","        padding: 1rem;\n","    }\n","\n","    .model-tag {\n","        display: inline-block;\n","        padding: 0.3rem 0.7rem;\n","        border-radius: 15px;\n","        font-weight: 600;\n","        font-size: 0.7rem;\n","        color: white;\n","    }\n","\n","    .stButton > button {\n","        background: linear-gradient(135deg, #6366f1, #8b5cf6);\n","        color: white;\n","        border: none;\n","        padding: 0.75rem 1.5rem;\n","        border-radius: 25px;\n","        font-weight: 600;\n","    }\n","\n","    .stTabs [data-baseweb=\"tab-list\"] {\n","        background: rgba(255,255,255,0.02);\n","        padding: 0.4rem;\n","        border-radius: 12px;\n","    }\n","\n","    .stTabs [aria-selected=\"true\"] {\n","        background: linear-gradient(135deg, #6366f1, #8b5cf6);\n","        color: white;\n","    }\n","\n","    .emotion-chip {\n","        display: inline-flex;\n","        align-items: center;\n","        background: rgba(255,255,255,0.05);\n","        border-radius: 20px;\n","        padding: 0.4rem 0.8rem;\n","        margin: 0.2rem;\n","    }\n","\n","    .gpu-badge {\n","        background: linear-gradient(135deg, #10b981, #059669);\n","        color: white;\n","        padding: 0.3rem 0.8rem;\n","        border-radius: 15px;\n","        font-size: 0.75rem;\n","        font-weight: 600;\n","    }\n","\n","    .app-footer {\n","        text-align: center;\n","        padding: 1.5rem;\n","        margin-top: 2rem;\n","        border-top: 1px solid rgba(255,255,255,0.1);\n","        color: rgba(255,255,255,0.5);\n","    }\n","</style>\n","\"\"\", unsafe_allow_html=True)\n","\n","# ============================================================================\n","# PATHS CONFIGURATION\n","# ============================================================================\n","SHARED_DRIVE = Path('/content/drive/Shareddrives/Vision-LLM-Project-Team')\n","MODELS_DIR = SHARED_DRIVE / 'models'\n","RESULTS_DIR = SHARED_DRIVE / 'results'\n","BLIP2_MODEL_DIR = MODELS_DIR / 'blip2-model' / 'best_model'\n","BLIP2_RESULTS_DIR = RESULTS_DIR / 'results_blip2'\n","\n","# LLaVA paths (feature extraction approach)\n","LLAVA_FEATURES_PATH = MODELS_DIR / 'llava_features.pt'\n","LLAVA_CLASSIFIER_PATH = MODELS_DIR / 'llava_classifier_best.pth'\n","\n","# ============================================================================\n","# EMOTION DATA\n","# ============================================================================\n","EMOTIONS = {\n","    0: {\"name\": \"happily surprised\", \"icon\": \"😲😊\", \"color\": \"#fbbf24\"},\n","    1: {\"name\": \"happily disgusted\", \"icon\": \"😊🤢\", \"color\": \"#84cc16\"},\n","    2: {\"name\": \"sadly fearful\", \"icon\": \"😢😨\", \"color\": \"#3b82f6\"},\n","    3: {\"name\": \"sadly angry\", \"icon\": \"😢😠\", \"color\": \"#ef4444\"},\n","    4: {\"name\": \"sadly surprised\", \"icon\": \"😢😮\", \"color\": \"#60a5fa\"},\n","    5: {\"name\": \"sadly disgusted\", \"icon\": \"😢🤢\", \"color\": \"#6b7280\"},\n","    6: {\"name\": \"fearfully angry\", \"icon\": \"😨😠\", \"color\": \"#f97316\"},\n","    7: {\"name\": \"fearfully surprised\", \"icon\": \"😨😮\", \"color\": \"#a855f7\"},\n","    8: {\"name\": \"fearfully disgusted\", \"icon\": \"😨🤢\", \"color\": \"#14b8a6\"},\n","    9: {\"name\": \"angrily surprised\", \"icon\": \"😠😮\", \"color\": \"#f43f5e\"},\n","    10: {\"name\": \"angrily disgusted\", \"icon\": \"😠🤢\", \"color\": \"#dc2626\"},\n","    11: {\"name\": \"disgustedly surprised\", \"icon\": \"🤢😮\", \"color\": \"#65a30d\"},\n","    12: {\"name\": \"happily fearful\", \"icon\": \"😊😨\", \"color\": \"#ec4899\"},\n","    13: {\"name\": \"happily sad\", \"icon\": \"😊😢\", \"color\": \"#c084fc\"}\n","}\n","\n","EMOTION_DESCRIPTIONS = {\n","    \"happily surprised\": \"Joy and amazement - wide smile, raised eyebrows, open mouth.\",\n","    \"happily disgusted\": \"Amused disgust - smile with wrinkled nose.\",\n","    \"sadly fearful\": \"Vulnerable fear - downturned mouth, worried eyes.\",\n","    \"sadly angry\": \"Hurt anger - furrowed brow, downturned mouth.\",\n","    \"sadly surprised\": \"Disappointed shock - raised eyebrows, wide sad eyes.\",\n","    \"sadly disgusted\": \"Disappointed disgust - wrinkled nose, sad eyes.\",\n","    \"fearfully angry\": \"Defensive rage - wide tense eyes, furrowed brow.\",\n","    \"fearfully surprised\": \"Alarmed - very wide eyes, raised eyebrows.\",\n","    \"fearfully disgusted\": \"Threatened revulsion - wrinkled nose, wide eyes.\",\n","    \"angrily surprised\": \"Outraged - furrowed brow, wide eyes.\",\n","    \"angrily disgusted\": \"Furious revulsion - deep frown, wrinkled nose.\",\n","    \"disgustedly surprised\": \"Shocked revulsion - wide eyes, wrinkled nose.\",\n","    \"happily fearful\": \"Nervous excitement - nervous smile, wide eyes.\",\n","    \"happily sad\": \"Bittersweet - slight smile, teary eyes.\"\n","}\n","\n","# BLIP-2 Facial Feature Descriptions\n","FACIAL_FEATURES = {\n","    \"happily surprised\": \"eyebrows raised high showing surprise, eyes wide open, mouth open in an 'O' shape with visible smile\",\n","    \"happily disgusted\": \"eyebrows slightly raised, nose wrinkled showing disgust, but mouth corners turned upward in amusement\",\n","    \"sadly fearful\": \"eyebrows pulled together and raised showing fear, eyes wide with worry, mouth corners turned down\",\n","    \"sadly angry\": \"eyebrows lowered and drawn together in anger, eyes narrowed, mouth corners turned down showing sadness\",\n","    \"sadly surprised\": \"eyebrows raised in surprise, eyes wide but with downturned outer corners, mouth open with downturned corners\",\n","    \"sadly disgusted\": \"eyebrows lowered, nose wrinkled in disgust, mouth corners turned down, overall drooping expression\",\n","    \"fearfully angry\": \"eyebrows lowered showing anger but with tension, eyes wide with fear, jaw clenched\",\n","    \"fearfully surprised\": \"eyebrows raised very high, eyes extremely wide showing alarm, mouth open in shock\",\n","    \"fearfully disgusted\": \"eyebrows raised with tension, eyes wide with fear, nose wrinkled, upper lip raised\",\n","    \"angrily surprised\": \"eyebrows raised but drawn together, eyes wide with anger, mouth open showing outrage\",\n","    \"angrily disgusted\": \"eyebrows severely lowered and drawn together, nose wrinkled, upper lip raised in contempt\",\n","    \"disgustedly surprised\": \"eyebrows raised in surprise, nose heavily wrinkled, mouth open showing shock and revulsion\",\n","    \"happily fearful\": \"eyebrows raised showing fear, eyes wide but with crow's feet from smiling, nervous smile visible\",\n","    \"happily sad\": \"eyebrows slightly lowered showing sadness, eyes show tears but mouth has slight upturn (bittersweet)\"\n","}\n","\n","# ============================================================================\n","# UTILITY FUNCTIONS\n","# ============================================================================\n","@st.cache_data(ttl=3600)\n","def load_results_file(path_str):\n","    try:\n","        path = Path(path_str)\n","        if path.exists():\n","            with open(path, 'r') as f:\n","                return json.load(f)\n","    except:\n","        pass\n","    return None\n","\n","def get_all_model_results():\n","    results = {}\n","\n","    resnet = load_results_file(str(RESULTS_DIR / 'resnet_results.json'))\n","    if resnet:\n","        results['ResNet50'] = {\n","            'accuracy': resnet.get('accuracy', 0),\n","            'f1_score': resnet.get('f1_score', 0),\n","            'precision': resnet.get('precision', 0),\n","            'recall': resnet.get('recall', 0),\n","            'type': 'CNN', 'color': '#3b82f6', 'icon': '⚡'\n","        }\n","\n","    vit = load_results_file(str(RESULTS_DIR / 'vit_results.json'))\n","    if vit:\n","        results['ViT-Small'] = {\n","            'accuracy': vit.get('accuracy', 0),\n","            'f1_score': vit.get('f1_score', 0),\n","            'precision': vit.get('precision', 0),\n","            'recall': vit.get('recall', 0),\n","            'type': 'Transformer', 'color': '#ef4444', 'icon': '👁️'\n","        }\n","\n","    llava = load_results_file(str(RESULTS_DIR / 'llava_results.json'))\n","    if llava:\n","        results['LLaVA-1.5'] = {\n","            'accuracy': llava.get('accuracy', 0),\n","            'f1_score': llava.get('f1_score', 0),\n","            'precision': llava.get('precision', 0),\n","            'recall': llava.get('recall', 0),\n","            'type': 'Vision-LLM', 'color': '#10b981', 'icon': '🧠'\n","        }\n","\n","    blip2 = load_results_file(str(BLIP2_RESULTS_DIR / 'blip2_results.json'))\n","    if blip2:\n","        results['BLIP-2'] = {\n","            'accuracy': blip2.get('accuracy', 0),\n","            'f1_score': blip2.get('f1_score', 0),\n","            'precision': blip2.get('precision', 0),\n","            'recall': blip2.get('recall', 0),\n","            'type': 'Vision-LLM', 'color': '#8b5cf6', 'icon': '🚀'\n","        }\n","\n","    return results\n","\n","# ============================================================================\n","# LLAVA CLASSIFIER (Same architecture as training)\n","# ============================================================================\n","class UltraEmotionClassifier(nn.Module):\n","    \"\"\"LLaVA Classifier - Same architecture as in training notebook\"\"\"\n","    def __init__(self, input_dim, num_classes):\n","        super().__init__()\n","\n","        self.input_norm = nn.LayerNorm(input_dim)\n","\n","        self.attention = nn.MultiheadAttention(\n","            embed_dim=input_dim,\n","            num_heads=8,\n","            dropout=0.1,\n","            batch_first=True\n","        )\n","        self.attn_norm = nn.LayerNorm(input_dim)\n","\n","        self.fc1 = nn.Linear(input_dim, 2048)\n","        self.bn1 = nn.BatchNorm1d(2048)\n","        self.fc2 = nn.Linear(2048, 1024)\n","        self.bn2 = nn.BatchNorm1d(1024)\n","        self.fc3 = nn.Linear(1024, 512)\n","        self.bn3 = nn.BatchNorm1d(512)\n","        self.fc4 = nn.Linear(512, 256)\n","        self.bn4 = nn.BatchNorm1d(256)\n","\n","        self.skip1 = nn.Linear(input_dim, 2048)\n","        self.skip2 = nn.Linear(2048, 1024)\n","        self.skip3 = nn.Linear(1024, 512)\n","\n","        self.classifier = nn.Sequential(\n","            nn.Dropout(0.4),\n","            nn.Linear(256, 128),\n","            nn.GELU(),\n","            nn.Dropout(0.2),\n","            nn.Linear(128, num_classes)\n","        )\n","\n","        self.dropout = nn.Dropout(0.3)\n","\n","    def forward(self, x):\n","        x = self.input_norm(x)\n","\n","        x_attn = x.unsqueeze(1)\n","        attn_out, _ = self.attention(x_attn, x_attn, x_attn)\n","        x = x + attn_out.squeeze(1)\n","        x = self.attn_norm(x)\n","\n","        identity = self.skip1(x)\n","        x = F.gelu(self.bn1(self.fc1(x)))\n","        x = self.dropout(x)\n","        x = x + identity\n","\n","        identity = self.skip2(x)\n","        x = F.gelu(self.bn2(self.fc2(x)))\n","        x = self.dropout(x)\n","        x = x + identity\n","\n","        identity = self.skip3(x)\n","        x = F.gelu(self.bn3(self.fc3(x)))\n","        x = self.dropout(x)\n","        x = x + identity\n","\n","        x = F.gelu(self.bn4(self.fc4(x)))\n","\n","        return self.classifier(x)\n","\n","# ============================================================================\n","# MODEL LOADING FUNCTIONS\n","# ============================================================================\n","@st.cache_resource\n","def load_resnet_model():\n","    try:\n","        class ResNetModel(nn.Module):\n","            def __init__(self, num_classes=14):\n","                super().__init__()\n","                self.resnet = models.resnet50(weights=None)\n","                num_features = self.resnet.fc.in_features\n","                self.resnet.fc = nn.Sequential(\n","                    nn.Dropout(0.5),\n","                    nn.Linear(num_features, 512),\n","                    nn.BatchNorm1d(512),\n","                    nn.ReLU(),\n","                    nn.Dropout(0.4),\n","                    nn.Linear(512, num_classes)\n","                )\n","            def forward(self, x):\n","                return self.resnet(x)\n","\n","        model = ResNetModel(14)\n","        model_path = MODELS_DIR / 'resnet50_best.pth'\n","\n","        if model_path.exists():\n","            model.load_state_dict(torch.load(model_path, map_location=DEVICE, weights_only=True))\n","            model = model.to(DEVICE)\n","            model.eval()\n","            return model, True\n","        return None, False\n","    except:\n","        return None, False\n","\n","@st.cache_resource\n","def load_vit_model():\n","    try:\n","        import timm\n","\n","        class ViTModel(nn.Module):\n","            def __init__(self, num_classes=14):\n","                super().__init__()\n","                self.vit = timm.create_model('vit_small_patch16_224', pretrained=False)\n","                num_features = self.vit.head.in_features\n","                self.vit.head = nn.Sequential(\n","                    nn.LayerNorm(num_features),\n","                    nn.Dropout(0.3),\n","                    nn.Linear(num_features, num_classes)\n","                )\n","            def forward(self, x):\n","                return self.vit(x)\n","\n","        model = ViTModel(14)\n","        model_path = MODELS_DIR / 'vit_best.pth'\n","\n","        if model_path.exists():\n","            model.load_state_dict(torch.load(model_path, map_location=DEVICE, weights_only=True))\n","            model = model.to(DEVICE)\n","            model.eval()\n","            return model, True\n","        return None, False\n","    except:\n","        return None, False\n","\n","@st.cache_resource\n","def load_llava_model():\n","    \"\"\"Load LLaVA Vision Tower + Classifier\"\"\"\n","    try:\n","        from transformers import LlavaForConditionalGeneration, AutoProcessor, BitsAndBytesConfig\n","\n","        # Check if classifier exists\n","        if not LLAVA_CLASSIFIER_PATH.exists():\n","            return None, None, None, False\n","\n","        # Load the classifier\n","        feature_dim = 1024  # LLaVA 1.5 vision tower hidden size\n","        num_classes = 14\n","\n","        classifier = UltraEmotionClassifier(feature_dim, num_classes)\n","        checkpoint = torch.load(LLAVA_CLASSIFIER_PATH, map_location=DEVICE, weights_only=True)\n","        classifier.load_state_dict(checkpoint['model_state_dict'])\n","        classifier = classifier.to(DEVICE)\n","        classifier.eval()\n","\n","        # Load LLaVA vision tower for feature extraction\n","        quant_config = BitsAndBytesConfig(\n","            load_in_4bit=True,\n","            bnb_4bit_quant_type=\"nf4\",\n","            bnb_4bit_compute_dtype=torch.float16,\n","            bnb_4bit_use_double_quant=False\n","        )\n","\n","        model_id = \"llava-hf/llava-1.5-7b-hf\"\n","        processor = AutoProcessor.from_pretrained(model_id)\n","\n","        llava_model = LlavaForConditionalGeneration.from_pretrained(\n","            model_id,\n","            quantization_config=quant_config,\n","            device_map=\"auto\",\n","            torch_dtype=torch.float16,\n","            low_cpu_mem_usage=True\n","        )\n","        llava_model.eval()\n","\n","        # Get vision tower\n","        vision_tower = llava_model.model.vision_tower\n","        vision_tower.eval()\n","\n","        return vision_tower, classifier, processor, True\n","    except Exception as e:\n","        st.error(f\"LLaVA load error: {e}\")\n","        return None, None, None, False\n","\n","@st.cache_resource\n","def load_blip2_model():\n","    \"\"\"Load BLIP-2 with LoRA adapters\"\"\"\n","    try:\n","        from transformers import Blip2Processor, Blip2ForConditionalGeneration, BitsAndBytesConfig\n","        from peft import PeftModel\n","\n","        if not BLIP2_MODEL_DIR.exists():\n","            return None, None, False\n","\n","        # Check if processor files exist in saved model\n","        processor_files = ['preprocessor_config.json', 'tokenizer_config.json']\n","        has_processor = any((BLIP2_MODEL_DIR / f).exists() for f in processor_files)\n","\n","        if has_processor:\n","            processor = Blip2Processor.from_pretrained(BLIP2_MODEL_DIR)\n","        else:\n","            processor = Blip2Processor.from_pretrained(\"Salesforce/blip2-opt-2.7b\")\n","\n","        quant_config = BitsAndBytesConfig(\n","            load_in_4bit=True,\n","            bnb_4bit_compute_dtype=torch.float16,\n","            bnb_4bit_use_double_quant=True,\n","            bnb_4bit_quant_type=\"nf4\"\n","        )\n","\n","        base_model = Blip2ForConditionalGeneration.from_pretrained(\n","            \"Salesforce/blip2-opt-2.7b\",\n","            quantization_config=quant_config,\n","            device_map=\"auto\",\n","            torch_dtype=torch.float16,\n","            low_cpu_mem_usage=True\n","        )\n","\n","        # Load LoRA adapters\n","        try:\n","            model = PeftModel.from_pretrained(base_model, BLIP2_MODEL_DIR, is_trainable=False)\n","        except:\n","            # If LoRA loading fails, use base model\n","            model = base_model\n","\n","        model.eval()\n","        return model, processor, True\n","    except:\n","        return None, None, False\n","\n","# ============================================================================\n","# PREDICTION FUNCTIONS\n","# ============================================================================\n","def get_image_transform():\n","    return transforms.Compose([\n","        transforms.Resize((224, 224)),\n","        transforms.ToTensor(),\n","        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n","    ])\n","\n","def get_llava_transform():\n","    \"\"\"LLaVA uses 336x336 images with CLIP normalization\"\"\"\n","    return transforms.Compose([\n","        transforms.Resize((336, 336)),\n","        transforms.ToTensor(),\n","        transforms.Normalize(\n","            mean=[0.48145466, 0.4578275, 0.40821073],\n","            std=[0.26862954, 0.26130258, 0.27577711]\n","        )\n","    ])\n","\n","def predict_cnn_vit(model, image, model_name=\"Model\"):\n","    try:\n","        transform = get_image_transform()\n","        tensor = transform(image).unsqueeze(0).to(DEVICE)\n","\n","        with torch.no_grad():\n","            if torch.cuda.is_available():\n","                with torch.cuda.amp.autocast():\n","                    outputs = model(tensor)\n","            else:\n","                outputs = model(tensor)\n","\n","            probs = F.softmax(outputs, dim=1)\n","            conf, pred_idx = torch.max(probs, 1)\n","\n","            top5_prob, top5_idx = torch.topk(probs, 5, dim=1)\n","            top5 = [(EMOTIONS[i.item()][\"name\"], p.item()) for i, p in zip(top5_idx[0], top5_prob[0])]\n","            all_probs = {EMOTIONS[i][\"name\"]: probs[0][i].item() for i in range(14)}\n","\n","            return {\n","                \"idx\": pred_idx.item(),\n","                \"emotion\": EMOTIONS[pred_idx.item()][\"name\"],\n","                \"icon\": EMOTIONS[pred_idx.item()][\"icon\"],\n","                \"confidence\": conf.item(),\n","                \"top5\": top5,\n","                \"all_probs\": all_probs,\n","                \"explanation\": None\n","            }\n","    except Exception as e:\n","        st.error(f\"Error ({model_name}): {e}\")\n","        return None\n","\n","def predict_llava(vision_tower, classifier, processor, image):\n","    \"\"\"Predict using LLaVA feature extraction + classifier\"\"\"\n","    try:\n","        # Preprocess image for LLaVA vision tower\n","        transform = get_llava_transform()\n","        pixel_values = transform(image).unsqueeze(0).to(DEVICE)\n","\n","        with torch.no_grad():\n","            # Extract features from vision tower\n","            outputs = vision_tower(pixel_values, output_hidden_states=True)\n","\n","            # Global average pooling of last hidden state\n","            features = outputs.last_hidden_state.mean(dim=1)  # [1, hidden_dim]\n","\n","            # Convert to float32 for classifier\n","            features = features.float()\n","\n","            # Get prediction from classifier\n","            logits = classifier(features)\n","\n","            # Apply temperature scaling for calibration\n","            temperature = 1.5\n","            scaled_logits = logits / temperature\n","\n","            probs = F.softmax(scaled_logits, dim=1)\n","            conf, pred_idx = torch.max(probs, 1)\n","\n","            # Get top 5\n","            top5_prob, top5_idx = torch.topk(probs, 5, dim=1)\n","            top5 = [(EMOTIONS[i.item()][\"name\"], p.item()) for i, p in zip(top5_idx[0], top5_prob[0])]\n","\n","            # Get all probabilities\n","            all_probs = {EMOTIONS[i][\"name\"]: probs[0][i].item() for i in range(14)}\n","\n","            # Generate explanation based on prediction\n","            emotion_name = EMOTIONS[pred_idx.item()][\"name\"]\n","            explanation = f\"Detected {emotion_name}. {EMOTION_DESCRIPTIONS.get(emotion_name, '')}\"\n","\n","            return {\n","                \"idx\": pred_idx.item(),\n","                \"emotion\": emotion_name,\n","                \"icon\": EMOTIONS[pred_idx.item()][\"icon\"],\n","                \"confidence\": conf.item(),\n","                \"top5\": top5,\n","                \"all_probs\": all_probs,\n","                \"explanation\": explanation\n","            }\n","    except Exception as e:\n","        st.error(f\"LLaVA error: {e}\")\n","        import traceback\n","        traceback.print_exc()\n","        return None\n","\n","# =============================================================================\n","# FIXED BLIP-2 PREDICTION FUNCTION FOR STREAMLIT\n","# Replace the predict_blip2 function in your app.py with this\n","# =============================================================================\n","\n","def predict_blip2(model, processor, image):\n","    \"\"\"\n","    BLIP-2 prediction with robust parsing - FIXED VERSION\n","    Matches evaluation methodology for consistency\n","    \"\"\"\n","    try:\n","        # Build emotion list for prompt\n","        emotions_list = \", \".join([EMOTIONS[i][\"name\"] for i in range(14)])\n","\n","        # Use CLASSIFICATION prompt (same as evaluation)\n","        prompt = f\"Question: What compound emotion is shown in this face? Choose from: {emotions_list}. Answer:\"\n","\n","        # Process inputs\n","        inputs = processor(images=image, text=prompt, return_tensors=\"pt\")\n","        inputs = {k: v.to(model.device) for k, v in inputs.items()}\n","\n","        # Generate prediction\n","        with torch.no_grad():\n","            generated_ids = model.generate(\n","                **inputs,\n","                max_new_tokens=20,\n","                num_beams=1,\n","                do_sample=False,\n","                pad_token_id=processor.tokenizer.pad_token_id\n","            )\n","\n","        # Decode output\n","        generated_text = processor.tokenizer.decode(\n","            generated_ids[0],\n","            skip_special_tokens=True\n","        )\n","\n","        # Clean the generated text\n","        generated_lower = generated_text.lower().strip()\n","\n","        # Remove echoed prompt if present\n","        if \"answer:\" in generated_lower:\n","            generated_lower = generated_lower.split(\"answer:\")[-1].strip()\n","\n","        # Parse emotion using robust multi-level strategy\n","        pred_idx, confidence = parse_blip2_emotion(generated_lower)\n","\n","        # Get predicted emotion details\n","        predicted_emotion = EMOTIONS[pred_idx][\"name\"]\n","\n","        # Build probability distribution based on confidence\n","        all_probs = {}\n","        for idx, emo in EMOTIONS.items():\n","            if idx == pred_idx:\n","                all_probs[emo[\"name\"]] = confidence\n","            else:\n","                # Distribute remaining probability among other classes\n","                all_probs[emo[\"name\"]] = (1 - confidence) / 13\n","\n","        # Create top 5 predictions\n","        sorted_probs = sorted(all_probs.items(), key=lambda x: x[1], reverse=True)\n","        top5 = sorted_probs[:5]\n","\n","        # Generate explanation\n","        predicted_emotion = EMOTIONS[pred_idx][\"name\"]\n","\n","        # Build explanation safely using chr(10) for newline\n","        explanation = \"Detected: \" + predicted_emotion + chr(10)\n","        explanation += \"Confidence: \" + f\"{confidence:.1%}\" + chr(10)\n","        explanation += \"Facial features: \" + FACIAL_FEATURES.get(predicted_emotion, \"Analysis unavailable\")\n","        return {\n","            \"idx\": pred_idx,\n","            \"emotion\": predicted_emotion,\n","            \"icon\": EMOTIONS[pred_idx][\"icon\"],\n","            \"confidence\": confidence,\n","            \"top5\": top5,\n","            \"all_probs\": all_probs,\n","            \"explanation\": explanation,\n","            \"raw_output\": generated_text[:200] if len(generated_text) > 200 else generated_text,\n","            \"parsed_emotion\": generated_lower[:50] if len(generated_lower) > 50 else generated_lower\n","        }\n","\n","    except Exception as e:\n","        st.error(f\"BLIP-2 error: {e}\")\n","        import traceback\n","        st.error(traceback.format_exc())\n","        return None\n","\n","\n","def parse_blip2_emotion(text):\n","    \"\"\"\n","    Robust emotion parsing with confidence scoring\n","    Returns: (emotion_id, confidence_score)\n","    \"\"\"\n","    text_clean = text.lower().strip()\n","\n","    # Build emotion name to ID mapping\n","    emotion_to_id = {EMOTIONS[i][\"name\"].lower(): i for i in range(14)}\n","\n","    # === STRATEGY 1: Exact Match (Highest Confidence) ===\n","    for emotion_name, emotion_id in emotion_to_id.items():\n","        # Check if emotion name appears as standalone phrase\n","        if emotion_name in text_clean:\n","            # Verify it's not just a substring of another word\n","            if emotion_name == text_clean or f\" {emotion_name} \" in f\" {text_clean} \":\n","                return emotion_id, 0.90\n","\n","    # === STRATEGY 2: Both Components Present ===\n","    max_score = 0\n","    best_id = None\n","\n","    for emotion_id, emotion_data in EMOTIONS.items():\n","        emotion_name = emotion_data[\"name\"].lower()\n","        parts = emotion_name.split()  # e.g., [\"happily\", \"surprised\"]\n","\n","        if len(parts) == 2:\n","            score = 0\n","\n","            # Check for first component\n","            if parts[0] in text_clean:\n","                score += 2\n","\n","            # Check for second component\n","            if parts[1] in text_clean:\n","                score += 2\n","\n","            # Bonus if they appear together\n","            if emotion_name in text_clean:\n","                score += 3\n","\n","            # Track best match\n","            if score > max_score:\n","                max_score = score\n","                best_id = emotion_id\n","\n","    # Return if we found both components\n","    if max_score >= 4:  # Both parts found\n","        return best_id, 0.70\n","    elif max_score >= 2:  # One part found\n","        return best_id, 0.50\n","\n","    # === STRATEGY 3: Single Emotion Word Fallback ===\n","    single_emotion_map = {\n","        'happy': [0, 1, 12, 13],      # happily surprised, happily disgusted, etc.\n","        'sad': [2, 3, 4, 5, 13],       # sadly fearful, sadly angry, etc.\n","        'fear': [2, 6, 7, 8, 12],      # fearfully angry, etc.\n","        'angry': [3, 6, 9, 10],        # angrily surprised, etc.\n","        'disgust': [1, 5, 8, 10, 11],  # disgustedly surprised, etc.\n","        'surprise': [0, 4, 7, 9, 11]   # happily surprised, etc.\n","    }\n","\n","    for emotion_word, possible_ids in single_emotion_map.items():\n","        if emotion_word in text_clean:\n","            return possible_ids[0], 0.30\n","\n","    # === STRATEGY 4: Complete Parsing Failure ===\n","    # Default to a common class with very low confidence\n","    # This signals that the model couldn't generate a clear answer\n","    return 5, 0.10  # \"sadly disgusted\" as fallback with 10% confidence\n","\n","\n","# =============================================================================\n","# USAGE NOTES:\n","# =============================================================================\n","# 1. Replace the predict_blip2 function in your app.py with the version above\n","# 2. Add the parse_blip2_emotion helper function as well\n","# 3. The function now returns proper confidence scores\n","# 4. Low confidence (<0.5) indicates parsing difficulties\n","# 5. You can display confidence in the UI to show prediction reliability\n","\n","def generate_gradcam(model, image):\n","    try:\n","        from pytorch_grad_cam import GradCAM\n","        from pytorch_grad_cam.utils.image import show_cam_on_image\n","\n","        transform = get_image_transform()\n","        tensor = transform(image).unsqueeze(0).to(DEVICE)\n","\n","        target_layers = [model.resnet.layer4[-1]]\n","        cam = GradCAM(model=model, target_layers=target_layers)\n","        grayscale_cam = cam(input_tensor=tensor, targets=None)[0, :]\n","\n","        img = tensor.squeeze().cpu().numpy().transpose(1, 2, 0)\n","        img = np.clip(np.array([0.229, 0.224, 0.225]) * img + np.array([0.485, 0.456, 0.406]), 0, 1)\n","\n","        return show_cam_on_image(img.astype(np.float32), grayscale_cam, use_rgb=True)\n","    except:\n","        return None\n","\n","# ============================================================================\n","# INITIALIZE SESSION STATE\n","# ============================================================================\n","if 'predictions' not in st.session_state:\n","    st.session_state.predictions = {}\n","if 'current_image' not in st.session_state:\n","    st.session_state.current_image = None\n","\n","# ============================================================================\n","# LOAD MODELS AND RESULTS\n","# ============================================================================\n","resnet_model, resnet_ok = load_resnet_model()\n","vit_model, vit_ok = load_vit_model()\n","\n","# Check LLaVA and BLIP-2 availability\n","llava_classifier_available = LLAVA_CLASSIFIER_PATH.exists()\n","blip2_available = BLIP2_MODEL_DIR.exists()\n","\n","all_results = get_all_model_results()\n","\n","# ============================================================================\n","# SIDEBAR (keeping the same)\n","# ============================================================================\n","with st.sidebar:\n","    st.markdown(\"\"\"\n","    <div style=\"text-align: center; padding: 1rem; background: linear-gradient(135deg, rgba(99, 102, 241, 0.3), rgba(139, 92, 246, 0.3)); border-radius: 16px; margin-bottom: 1rem;\">\n","        <div style=\"font-size: 2.5rem;\">🎭</div>\n","        <h2 style=\"color: white; margin: 0.5rem 0; font-weight: 700; font-size: 1.3rem;\">Vision-LLM</h2>\n","        <p style=\"color: rgba(255,255,255,0.8); margin: 0; font-size: 0.8rem;\">Emotion Recognition AI</p>\n","    </div>\n","    \"\"\", unsafe_allow_html=True)\n","\n","    gpu_status = \"🟢 GPU\" if torch.cuda.is_available() else \"🟡 CPU\"\n","    gpu_name = torch.cuda.get_device_name(0)[:20] if torch.cuda.is_available() else \"CPU\"\n","    st.markdown(f\"\"\"\n","    <div style=\"background: rgba(16, 185, 129, 0.2); padding: 0.5rem; border-radius: 10px; text-align: center; margin-bottom: 1rem;\">\n","        <span class=\"gpu-badge\">{gpu_status}</span>\n","        <p style=\"color: rgba(255,255,255,0.7); font-size: 0.7rem; margin: 0.3rem 0 0 0;\">{gpu_name}</p>\n","    </div>\n","    \"\"\", unsafe_allow_html=True)\n","\n","    st.markdown(\"---\")\n","\n","    st.markdown(\"### 🧭 Navigation\")\n","    page = st.selectbox(\n","        \"Select Page\",\n","        [\"🏠 Home\", \"🔮 Predict\", \"🔬 Explain\", \"📊 Compare\", \"ℹ️ About\"],\n","        label_visibility=\"collapsed\"\n","    )\n","\n","    st.markdown(\"---\")\n","    st.markdown(\"### 🤖 Models Status\")\n","\n","    for name, status, color in [\n","        (\"ResNet50\", resnet_ok, \"#3b82f6\"),\n","        (\"ViT-Small\", vit_ok, \"#ef4444\"),\n","        (\"LLaVA-1.5\", llava_classifier_available, \"#10b981\"),\n","        (\"BLIP-2\", blip2_available, \"#8b5cf6\")\n","    ]:\n","        icon = \"✅\" if status else \"⏳\"\n","        st.markdown(f\"\"\"\n","        <div style=\"display: flex; align-items: center; padding: 0.4rem; margin: 0.2rem 0; background: rgba(255,255,255,0.03); border-radius: 8px; border-left: 3px solid {color};\">\n","            <span style=\"margin-right: 0.4rem;\">{icon}</span>\n","            <span style=\"color: white; font-size: 0.85rem;\">{name}</span>\n","        </div>\n","        \"\"\", unsafe_allow_html=True)\n","\n","    if all_results:\n","        st.markdown(\"---\")\n","        best = max(all_results.items(), key=lambda 